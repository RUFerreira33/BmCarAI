generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Carro {
  id                  String    @id @default(uuid()) @db.Uuid
  bmcarId             String?   @unique @map("bmcar_id") @db.VarChar(255)
  slug                String?   @unique @db.VarChar(255)
  url                 String    @unique @db.Text
  marca               String    @db.VarChar(100)
  modelo              String?   @db.VarChar(150)
  versao              String?   @db.VarChar(255)
  titulo              String    @db.VarChar(255)
  tipoAnuncio         String?   @map("tipo_anuncio") @db.VarChar(50)
  preco               Decimal?  @db.Decimal(12, 2)
  ano                 Int?
  quilometros         Int?
  combustivel         String?   @db.VarChar(50)
  transmissao         String?   @db.VarChar(50)
  potenciaCv          Int?      @map("potencia_cv")
  cilindrada          Int?
  traccao             String?   @db.VarChar(50)
  carrocaria          String?   @db.VarChar(100)
  cor                 String?   @db.VarChar(100)
  portas              Int?
  lugares             Int?
  localizacao         String?   @db.VarChar(255)
  descricao           String?   @db.Text
  ativo               Boolean   @default(true)
  ultimaSincronizacao DateTime? @map("ultima_sincronizacao")
  criadoEm            DateTime  @default(now()) @map("criado_em")
  atualizadoEm        DateTime  @updatedAt @map("atualizado_em")

  imagens         ImagemCarro[]
  caracteristicas CaracteristicaCarro[]
  recomendacoes   Recomendacao[]

  @@index([marca])
  @@index([modelo])
  @@index([tipoAnuncio])
  @@index([preco])
  @@index([ano])
  @@index([quilometros])
  @@index([combustivel])
  @@index([transmissao])
  @@index([carrocaria])
  @@index([cor])
  @@index([ativo])
  @@map("carros")
}

model ImagemCarro {
  id       String   @id @default(uuid()) @db.Uuid
  carroId  String   @map("carro_id") @db.Uuid
  url      String   @db.Text
  ordem    Int?
  criadoEm DateTime @default(now()) @map("criado_em")

  carro Carro @relation(fields: [carroId], references: [id], onDelete: Cascade)

  @@index([carroId])
  @@map("imagens_carro")
}

model CaracteristicaCarro {
  id       String   @id @default(uuid()) @db.Uuid
  carroId  String   @map("carro_id") @db.Uuid
  nome     String   @db.VarChar(255)
  valor    String?  @db.Text
  criadoEm DateTime @default(now()) @map("criado_em")

  carro Carro @relation(fields: [carroId], references: [id], onDelete: Cascade)

  @@index([carroId])
  @@map("caracteristicas_carro")
}

model PedidoChat {
  id                   String   @id @default(uuid()) @db.Uuid
  sessaoId             String?  @map("sessao_id") @db.VarChar(255)
  mensagem             String   @db.Text
  filtrosExtraidosJson Json?    @map("filtros_extraidos_json")
  criadoEm             DateTime @default(now()) @map("criado_em")

  recomendacoes Recomendacao[]

  @@index([sessaoId])
  @@map("pedidos_chat")
}

model Recomendacao {
  id           String   @id @default(uuid()) @db.Uuid
  pedidoId     String   @map("pedido_id") @db.Uuid
  carroId      String   @map("carro_id") @db.Uuid
  score        Decimal  @db.Decimal(6, 2)
  justificacao String?  @db.Text
  criadoEm     DateTime @default(now()) @map("criado_em")

  pedido PedidoChat @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  carro  Carro      @relation(fields: [carroId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@index([carroId])
  @@map("recomendacoes")
}
